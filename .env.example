# ==============================================================================
# CONFIGURACIÓN DEL ENTORNO LOCAL - PROYECTO ETL (MIGRACIÓN HETEROGÉNEA)
# ==============================================================================
# Instrucciones: Copia este archivo, renómbralo como '.env' en la raíz
# del proyecto y ajusta los valores según tu configuración local.
#
# Nota: Estos valores solo aplican cuando ejecutas el pipeline FUERA de
# Docker (localmente). Dentro de Docker, docker-compose.yml define las
# variables de entorno con los hosts de la red interna (sqlserver, postgres).

# 🔌 CONFIGURACIÓN DE SQL SERVER (Origen de Datos)
SQLSERVER_HOST=localhost
SQLSERVER_PORT=1435
SQLSERVER_DATABASE=SmartCleanOrigen
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=Grupo1@BDD!

# 🐘 CONFIGURACIÓN DE POSTGRESQL (Destino del ETL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=etl_destino
POSTGRES_USER=etl_user
POSTGRES_PASSWORD=Grupo1_PG!

# 🔑 CONTRASEÑAS USADAS POR DOCKER COMPOSE
MSSQL_SA_PASSWORD=Grupo1@BDD!
